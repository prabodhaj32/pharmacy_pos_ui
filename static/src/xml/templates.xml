            </aside>

            <!-- MAIN CONTENT -->
            <main class="main-content">

                <!-- TOP BAR -->
                <header class="topbar modern-header" role="banner">
                    <div class="header-left">
                        <h1 class="page-title">Dashboard</h1>
                    </div>

                    <div class="header-right">
                        <div class="header-info-group">
                            <t t-if="props.cashierId">
                                <div class="info-pill cashier-pill" aria-label="Cashier details">
                                    <span class="pill-icon">🧑</span>
                                    <span class="pill-text"><t t-esc="props.cashierName || props.cashierId"/> (<t t-esc="props.role"/>)</span>
                                </div>
                            </t>
                            <div class="info-pill date-pill" aria-label="Current date">
                                <span class="pill-icon">📅</span>
                                <span class="pill-text"><t t-esc="new Date().toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' })"/></span>
                            </div>
                            <div class="info-pill status-pill online" aria-label="System status">
                                <span class="status-dot"></span>
                                <span class="pill-text">Online</span>
                            </div>
                        </div>
                        
                        <div class="header-actions">
                            <button class="notification-trigger" aria-label="View notifications">
                                <span class="bell-icon">🔔</span>
                                <span id="notification-count" class="badge">5</span>
                            </button>
                        </div>
                    </div>
                </header>

                <!-- DASHBOARD CONTENT -->
                <section id="dashboard_container" role="main" aria-label="Dashboard content">
                    <!-- Dashboard content will be rendered here by JavaScript -->
                </section>

            </main>

        </div>
    </t>

    <!-- DASHBOARD METRICS TEMPLATE -->
    <t t-name="dashboard_metrics">
        <section class="metrics-grid" role="region" aria-label="Key performance indicators">
            <article class="metric-card success">
                <div class="metric-header">
                    <div>
                        <h3 class="metric-title">Today's Sales</h3>
                        <p class="metric-value">LKR 48,750</p>
                        <p class="metric-subtitle">34 invoices</p>
                    </div>
                    <div class="metric-icon" aria-hidden="true">💰</div>
                </div>
                <div class="metric-change positive">
                    <span aria-hidden="true">📈</span>
                    <span>+12.4% vs yesterday</span>
                </div>
            </article>

            <article class="metric-card info">
                <div class="metric-header">
                    <div>
                        <h3 class="metric-title">Customers Served</h3>
                        <p class="metric-value">28</p>
                        <p class="metric-subtitle">Avg. LKR 1,433.82/bill</p>
                    </div>
                    <div class="metric-icon" aria-hidden="true">👥</div>
                </div>
                <div class="metric-change positive">
                    <span aria-hidden="true">📊</span>
                    <span>+5 customers vs yesterday</span>
                </div>
            </article>

            <article class="metric-card success">
                <div class="metric-header">
                    <div>
                        <h3 class="metric-title">Gross Profit</h3>
                        <p class="metric-value">LKR 18,420</p>
                        <p class="metric-subtitle">37.8% margin</p>
                    </div>
                    <div class="metric-icon" aria-hidden="true">📈</div>
                </div>
                <div class="metric-change positive">
                    <span aria-hidden="true">💹</span>
                    <span>+8.2% vs yesterday</span>
                </div>
            </article>

            <article class="metric-card danger">
                <div class="metric-header">
                    <div>
                        <h3 class="metric-title">Returns Today</h3>
                        <p class="metric-value">LKR 1,200</p>
                        <p class="metric-subtitle">2 return transactions</p>
                    </div>
                    <div class="metric-icon" aria-hidden="true">🔄</div>
                </div>
                <div class="metric-change negative">
                    <span aria-hidden="true">📉</span>
                    <span>-LKR 300 vs yesterday</span>
                </div>
            </article>
        </section>
    </t>

    <!-- CHARTS TEMPLATE -->
    <t t-name="dashboard_charts">
        <section class="charts-grid" role="region" aria-label="Charts and analytics">
            <article class="chart-card">
                <div class="chart-header">
                    <div>
                        <h3 class="chart-title">Weekly Sales &amp; Profit</h3>
                        <p class="chart-subtitle">Last 7 days performance</p>
                    </div>
                    <select class="chart-filter" aria-label="Filter chart data" onchange="dashboard.updateWeeklyChart(this.value)">
                        <option value="sales">Sales</option>
                        <option value="profit">Profit</option>
                        <option value="both">Both</option>
                    </select>
                </div>
                <div class="chart-container">
                    <canvas id="weeklyChart" aria-label="Weekly sales and profit chart"></canvas>
                </div>
            </article>

            <article class="chart-card">
                <div class="chart-header">
                    <div>
                        <h3 class="chart-title">Sales by Category</h3>
                        <p class="chart-subtitle">Today's sales by category</p>
                    </div>
                </div>
                <div class="chart-container small">
                    <canvas id="categoryChart" aria-label="Sales by category donut chart"></canvas>
                </div>
            </article>
        </section>
    </t>

    <!-- ADDITIONAL STATS TEMPLATE -->
    <t t-name="dashboard_stats">
        <section class="dashboard-grid" role="region" aria-label="Additional statistics">
            <article class="card">
                <h3>Low Stock Alerts</h3>
                <p>12 medicines need restocking</p>
            </article>
            <article class="card">
                <h3>Expiring Soon</h3>
                <p>8 medicines expire in 30 days</p>
            </article>
            <article class="card">
                <h3>Pending Orders</h3>
                <p>5 supplier orders pending</p>
            </article>
        </section>
    </t>

    <!-- INVENTORY TEMPLATE -->
    <t t-name="pharmacy_inventory_layout">
        <div id="pharmacy_inventory_app">
            <!-- Inventory content will be rendered here by JavaScript -->
        </div>
    </t>

    <!-- LEGACY DASHBOARD CONTENT (for backward compatibility) -->
    <t t-name="PharmacyDashboard">
        <section class="cards" role="region" aria-label="Dashboard cards">
            <article class="card">
                <h3>Today Sales</h3>
                <p>LKR 48,750</p>
            </article>

            <article class="card">
                <h3>Medicines</h3>
                <p>320</p>
            </article>

            <article class="card">
                <h3>Customers</h3>
                <p>150</p>
            </article>

            <article class="card danger">
                <h3>Returns</h3>
                <p>LKR 1,200</p>
            </article>
        </section>
    </t>

</templates>